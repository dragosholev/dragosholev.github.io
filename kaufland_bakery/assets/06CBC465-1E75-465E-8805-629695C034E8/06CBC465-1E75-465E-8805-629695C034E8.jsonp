в незабравимо зрелище. Те са атрактивни, защото съчетават музика, танц и емоция в едно цялостно изживяване. Така и ние искаме да превърнем Kaufland в сцена, където пазаруването се превръща в забавление.","targetRectangle":{"y":445.28705215454102,"x":164.09474182128906,"width":527.51220703125,"height":200}},{"text":"cff3f6ad-f99d-4b3c-b6cd-7b2107dfd9fd_md.jpeg","targetRectangle":{"y":373.25753784179688,"x":701.2548828125,"width":1217.84375,"height":395.19290739301687}},{"text":"All rights ","targetRectangle":{"y":399.76530175781249,"x":1865.4568042755127,"width":22.439998865127563,"height":77.307999999999993}},{"text":"reserved","targetRectangle":{"y":405.30930175781248,"x":1888.4568042755127,"width":22.439998865127563,"height":70.700000000000045}},{"text":"1453798a02b9e15acb524c87da0aceeb.png","targetRectangle":{"y":92.162422180175781,"x":-213.46226501464844,"width":377.89483642578125,"height":375.21478271484375}},{"text":"Bakery ","targetRectangle":{"y":664.9169834594727,"x":1884.5822105407715,"width":30,"height":72.13799999999992}},{"text":"Интро","targetRectangle":{"y":-12821.674102783203,"x":174.02467346191406,"width":289.0625,"height":120}},{"text":"Артистичен подход","targetRectangle":{"y":-11741.674102783203,"x":174.02467346191406,"width":920.99609375,"height":120}},{"text":"Настроение","targetRectangle":{"y":-10781.674102783203,"x":174.02467346191406,"width":564.2578125,"height":120}},{"text":"Храната","targetRectangle":{"y":-9821.6741027832031,"x":174.02467346191406,"width":394.775390625,"height":120}},{"text":"Кастинг","targetRectangle":{"y":-8741.6741027832031,"x":174.02467346191406,"width":376.5625,"height":120}},{"text":"Локация","targetRectangle":{"y":-7301.6741027832031,"x":174.02467346191406,"width":405.908203125,"height":120}},{"text":"Сценография","targetRectangle":{"y":-6101.6741027832031,"x":174.02467346191406,"width":645.01953125,"height":120}},{"text":"Разкадровка","targetRectangle":{"y":-5381.6741027832031,"x":174.02467346191406,"width":619.72