"width":768.82763671875,"height":125}},{"text":"Когато Христо Стоичков разбере кой е неговият бъдещ екранен партньор той трябва да реагира така …","targetRectangle":{"y":421.32118617918024,"x":125.83930402790476,"width":747.919921875,"height":50}},{"text":"Bakery ","targetRectangle":{"y":664.9169834594727,"x":1884.5822105407715,"width":30,"height":72.13799999999992}},{"text":"Интро","targetRectangle":{"y":-3918.317626934389,"x":286.02398622551885,"width":289.06250000000006,"height":120}},{"text":"Артистичен подход","targetRectangle":{"y":-2838.317626934389,"x":286.02398622551885,"width":920.99609375,"height":120}},{"text":"Настроение","targetRectangle":{"y":-1878.317626934389,"x":286.02398622551885,"width":564.2578125,"height":120}},{"text":"Храната","targetRectangle":{"y":-918.31762693438895,"x":286.02398622551885,"width":394.77539062500006,"height":120}},{"text":"Кастинг","targetRectangle":{"y":161.68237306561105,"x":286.02398622551885,"width":376.56250000000006,"height":120}},{"text":"Локация","targetRectangle":{"y":1601.682373065611,"x":286.02398622551885,"width":405.90820312500006,"height":120}},{"text":"Сценография","targetRectangle":{"y":2081.682373065611,"x":286.02398622551885,"width":645.01953125,"height":120}},{"text":"Цветове","targetRectangle":{"y":2441.682373065611,"x":286.02398622551885,"width":399.60937500000006,"height":120}},{"text":"Светлина","targetRectangle":{"y":2921.682373065611,"x":286.02398622551885,"width":459.61914062500006,"height":120}},{"text":"Гардероб","targetRectangle":{"y":3161.682373065611,"x":286.02398622551885,"width":446.19140625000006,"height":120}},{"text":"Монтаж","targetRectangle":{"y":3641.682373065611,"x":286.02398622551885,"width":378.12500000000006,"height":120}},{"text":"Мюзикъл","targetRectangle":{"y":4001.682373065611,"x":286.02398622551885,"width":442.72460937500006,"height":119.99999999999955}},{"text":"Музика","targetRectangle":{"y":4481.6823730656106,"x":286.02398622551885,"width":352.05078125000006,"height":120}},